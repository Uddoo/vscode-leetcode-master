{
    "name": "leetcode-master",
    "displayName": "LeetCode Master",
    "description": "Practice LeetCode in VS Code with spaced repetition, review queues, and review analytics.",
    "version": "0.1.2",
    "author": "Uddoo",
    "publisher": "uddoo",
    "license": "MIT",
    "icon": "resources/LeetCode.png",
    "engines": {
        "vscode": "^1.57.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Uddoo/vscode-leetcode-master.git"
    },
    "homepage": "https://github.com/Uddoo/vscode-leetcode-master#readme",
    "bugs": {
        "url": "https://github.com/Uddoo/vscode-leetcode-master/issues"
    },
    "categories": [
        "Snippets"
    ],
    "keywords": [
        "leetcode",
        "spaced-repetition",
        "review",
        "frsr",
        "algorithm",
        "interview",
        "schedule",
        "analytics"
    ],
    "galleryBanner": {
        "color": "#1f2937",
        "theme": "dark"
    },
    "preview": false,
    "activationEvents": [
        "onCommand:leetcodeMaster.deleteCache",
        "onCommand:leetcodeMaster.toggleLeetCodeCn",
        "onCommand:leetcodeMaster.signin",
        "onCommand:leetcodeMaster.signout",
        "onCommand:leetcodeMaster.manageSessions",
        "onCommand:leetcodeMaster.refreshExplorer",
        "onCommand:leetcodeMaster.pickOne",
        "onCommand:leetcodeMaster.showProblem",
        "onCommand:leetcodeMaster.previewProblem",
        "onCommand:leetcodeMaster.searchProblem",
        "onCommand:leetcodeMaster.showSolution",
        "onCommand:leetcodeMaster.testSolution",
        "onCommand:leetcodeMaster.submitSolution",
        "onCommand:leetcodeMaster.addFavorite",
        "onCommand:leetcodeMaster.removeFavorite",
        "onCommand:leetcodeMaster.switchDefaultLanguage",
        "onCommand:leetcodeMaster.problems.sort",
        "onCommand:leetcodeMaster.review.showList",
        "onCommand:leetcodeMaster.review.refreshToday",
        "onCommand:leetcodeMaster.review.openTodayProblem",
        "onCommand:leetcodeMaster.review.showStats",
        "onView:leetcodeMasterExplorer",
        "onView:leetcodeMasterTodayReview"
    ],
    "main": "./out/src/extension",
    "contributes": {
        "commands": [
            {
                "command": "leetcodeMaster.deleteCache",
                "title": "Delete Cache",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.toggleLeetCodeCn",
                "title": "Switch Endpoint",
                "category": "LeetCode Master",
                "icon": "$(globe)"
            },
            {
                "command": "leetcodeMaster.signin",
                "title": "Sign In",
                "category": "LeetCode Master",
                "icon": "$(sign-in)"
            },
            {
                "command": "leetcodeMaster.signout",
                "title": "Sign Out",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.manageSessions",
                "title": "Manage Sessions",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.refreshExplorer",
                "title": "Refresh",
                "category": "LeetCode Master",
                "icon": "$(refresh)"
            },
            {
                "command": "leetcodeMaster.pickOne",
                "title": "Pick One",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.showProblem",
                "title": "Show Problem",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.previewProblem",
                "title": "Preview Problem",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.searchProblem",
                "title": "Search Problem",
                "category": "LeetCode Master",
                "icon": "$(search)"
            },
            {
                "command": "leetcodeMaster.showSolution",
                "title": "Show Top Voted Solution",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.testSolution",
                "title": "Test in LeetCode",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.submitSolution",
                "title": "Submit to LeetCode",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.addFavorite",
                "title": "Add to Favorite List",
                "category": "LeetCode Master",
                "icon": {
                    "light": "resources/light/like.png",
                    "dark": "resources/dark/like.png"
                }
            },
            {
                "command": "leetcodeMaster.removeFavorite",
                "title": "Remove from Favorite List",
                "category": "LeetCode Master",
                "icon": {
                    "light": "resources/light/dislike.png",
                    "dark": "resources/dark/dislike.png"
                }
            },
            {
                "command": "leetcodeMaster.switchDefaultLanguage",
                "title": "Switch Default Language",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.problems.sort",
                "title": "Sort Problems",
                "category": "LeetCode Master",
                "icon": "$(sort-precedence)"
            },
            {
                "command": "leetcodeMaster.review.showList",
                "title": "Show Review List",
                "category": "LeetCode Master",
                "icon": "$(checklist)"
            },
            {
                "command": "leetcodeMaster.review.refreshToday",
                "title": "Refresh Today Review",
                "category": "LeetCode Master",
                "icon": "$(refresh)"
            },
            {
                "command": "leetcodeMaster.review.openTodayProblem",
                "title": "Open Review Problem",
                "category": "LeetCode Master"
            },
            {
                "command": "leetcodeMaster.review.showStats",
                "title": "Show Review Stats",
                "category": "LeetCode Master",
                "icon": "$(graph)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "leetcodeMaster",
                    "title": "LeetCode Master",
                    "icon": "resources/LeetCode.svg"
                }
            ]
        },
        "views": {
            "leetcodeMaster": [
                {
                    "id": "leetcodeMasterExplorer",
                    "name": "Problems"
                },
                {
                    "id": "leetcodeMasterTodayReview",
                    "name": "Today Review"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "leetcodeMaster.toggleLeetCodeCn",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "navigation@0"
                },
                {
                    "command": "leetcodeMaster.signin",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "navigation@1"
                },
                {
                    "command": "leetcodeMaster.searchProblem",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "navigation@2"
                },
                {
                    "command": "leetcodeMaster.refreshExplorer",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "navigation@3"
                },
                {
                    "command": "leetcodeMaster.review.showList",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "navigation@4"
                },
                {
                    "command": "leetcodeMaster.review.showStats",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "navigation@5"
                },
                {
                    "command": "leetcodeMaster.review.refreshToday",
                    "when": "view == leetcodeMasterTodayReview",
                    "group": "navigation@0"
                },
                {
                    "command": "leetcodeMaster.review.showList",
                    "when": "view == leetcodeMasterTodayReview",
                    "group": "navigation@1"
                },
                {
                    "command": "leetcodeMaster.signout",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "overflow@1"
                },
                {
                    "command": "leetcodeMaster.pickOne",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "overflow@2"
                },
                {
                    "command": "leetcodeMaster.problems.sort",
                    "when": "view == leetcodeMasterExplorer",
                    "group": "overflow@3"
                }
            ],
            "view/item/context": [
                {
                    "command": "leetcodeMaster.previewProblem",
                    "when": "view == leetcodeMasterExplorer && viewItem =~ /problem*/",
                    "group": "leetcode@1"
                },
                {
                    "command": "leetcodeMaster.showProblem",
                    "when": "view == leetcodeMasterExplorer && viewItem =~ /problem*/",
                    "group": "leetcode@2"
                },
                {
                    "command": "leetcodeMaster.showSolution",
                    "when": "view == leetcodeMasterExplorer && viewItem =~ /problem*/",
                    "group": "leetcode@3"
                },
                {
                    "command": "leetcodeMaster.addFavorite",
                    "when": "view == leetcodeMasterExplorer && viewItem == problem",
                    "group": "inline"
                },
                {
                    "command": "leetcodeMaster.removeFavorite",
                    "when": "view == leetcodeMasterExplorer && viewItem == problem-favorite",
                    "group": "inline"
                }
            ],
            "commandPalette": [
                {
                    "command": "leetcodeMaster.showProblem",
                    "when": "never"
                },
                {
                    "command": "leetcodeMaster.showSolution",
                    "when": "never"
                },
                {
                    "command": "leetcodeMaster.previewProblem",
                    "when": "never"
                },
                {
                    "command": "leetcodeMaster.review.openTodayProblem",
                    "when": "never"
                },
                {
                    "command": "leetcodeMaster.addFavorite",
                    "when": "never"
                },
                {
                    "command": "leetcodeMaster.removeFavorite",
                    "when": "never"
                }
            ],
            "explorer/context": [
                {
                    "command": "leetcodeMaster.testSolution",
                    "when": "explorerResourceIsFolder == false",
                    "group": "leetcode@1"
                },
                {
                    "command": "leetcodeMaster.submitSolution",
                    "when": "explorerResourceIsFolder == false",
                    "group": "leetcode@2"
                }
            ],
            "editor/context": [
                {
                    "submenu": "leetcodeMaster.editorAction"
                }
            ],
            "leetcodeMaster.editorAction": [
                {
                    "command": "leetcodeMaster.testSolution",
                    "group": "leetcode@1"
                },
                {
                    "command": "leetcodeMaster.submitSolution",
                    "group": "leetcode@2"
                },
                {
                    "command": "leetcodeMaster.showSolution",
                    "group": "leetcode@3"
                },
                {
                    "command": "leetcodeMaster.previewProblem",
                    "group": "leetcode@4"
                }
            ]
        },
        "submenus": [
            {
                "id": "leetcodeMaster.editorAction",
                "label": "LeetCode Master"
            }
        ],
        "configuration": [
            {
                "title": "LeetCode Master",
                "properties": {
                    "leetcodeMaster.hideSolved": {
                        "type": "boolean",
                        "default": false,
                        "scope": "application",
                        "description": "Hide solved problems."
                    },
                    "leetcodeMaster.defaultLanguage": {
                        "type": "string",
                        "enum": [
                            "bash",
                            "c",
                            "cpp",
                            "csharp",
                            "golang",
                            "java",
                            "javascript",
                            "kotlin",
                            "mysql",
                            "php",
                            "python",
                            "python3",
                            "ruby",
                            "rust",
                            "scala",
                            "swift",
                            "typescript"
                        ],
                        "scope": "application",
                        "description": "Default language for solving the problems."
                    },
                    "leetcodeMaster.showDescription": {
                        "type": "string",
                        "default": "In Webview",
                        "enum": [
                            "In Webview",
                            "In File Comment",
                            "Both",
                            "None"
                        ],
                        "enumDescriptions": [
                            "Show the problem description in a new webview window",
                            "Show the problem description in the file's comment"
                        ],
                        "scope": "application",
                        "description": "Specify where to show the description."
                    },
                    "leetcodeMaster.showCommentDescription": {
                        "type": "boolean",
                        "default": false,
                        "scope": "application",
                        "description": "[Deprecated] Include problem description in comments.",
                        "deprecationMessage": "This setting will be deprecated in 0.17.0, please use 'leetcodeMaster.showDescription' instead"
                    },
                    "leetcodeMaster.hint.setDefaultLanguage": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Show a hint to set the default language."
                    },
                    "leetcodeMaster.hint.configWebviewMarkdown": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Show a hint to change webview appearance through markdown config."
                    },
                    "leetcodeMaster.hint.commentDescription": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Show a hint to enable comment description in solution code file."
                    },
                    "leetcodeMaster.hint.commandShortcut": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Show a hint to configure commands key binding."
                    },
                    "leetcodeMaster.useWsl": {
                        "type": "boolean",
                        "default": false,
                        "scope": "application",
                        "description": "Use the Windows Subsystem for Linux."
                    },
                    "leetcodeMaster.endpoint": {
                        "type": "string",
                        "default": "leetcode",
                        "scope": "application",
                        "enum": [
                            "leetcode",
                            "leetcode-cn"
                        ],
                        "description": "Endpoint of the user account."
                    },
                    "leetcodeMaster.useEndpointTranslation": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Use endpoint's translation (if available)"
                    },
                    "leetcodeMaster.workspaceFolder": {
                        "type": "string",
                        "scope": "application",
                        "description": "The path of the workspace folder to store the problem files.",
                        "default": ""
                    },
                    "leetcodeMaster.filePath": {
                        "type": "object",
                        "scope": "application",
                        "description": "The output folder and filename to save the problem files.",
                        "properties": {
                            "default": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string",
                                        "examples": [
                                            "src"
                                        ]
                                    },
                                    "filename": {
                                        "type": "string",
                                        "examples": [
                                            "${camelCaseName}.${ext}",
                                            "${PascalCaseName}.${ext}",
                                            "${id}-${kebab-case-name}.${ext}",
                                            "${id}_${snake_case_name}.${ext}"
                                        ]
                                    }
                                },
                                "required": [
                                    "folder",
                                    "filename"
                                ]
                            },
                            "bash": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "c": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "cpp": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "csharp": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "golang": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "java": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "javascript": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "kotlin": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "mysql": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "php": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "python": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "python3": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "ruby": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "rust": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "scala": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            },
                            "swift": {
                                "type": "object",
                                "properties": {
                                    "folder": {
                                        "type": "string"
                                    },
                                    "filename": {
                                        "type": "string"
                                    }
                                },
                                "minProperties": 1
                            }
                        },
                        "additionalProperties": {
                            "type": "object",
                            "properties": {
                                "folder": {
                                    "type": "string"
                                },
                                "filename": {
                                    "type": "string"
                                }
                            },
                            "minProperties": 1
                        },
                        "default": {
                            "default": {
                                "folder": "",
                                "filename": "${id}.${kebab-case-name}.${ext}"
                            }
                        }
                    },
                    "leetcodeMaster.enableStatusBar": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Show the LeetCode status bar or not."
                    },
                    "leetcodeMaster.editor.shortcuts": {
                        "type": "array",
                        "default": [
                            "submit",
                            "test"
                        ],
                        "scope": "application",
                        "items": {
                            "type": "string",
                            "enum": [
                                "submit",
                                "test",
                                "star",
                                "solution",
                                "description"
                            ],
                            "enumDescriptions": [
                                "Submit your answer to LeetCode.",
                                "Test your answer with customized test cases.",
                                "Star or unstar the current problem.",
                                "Show the top voted solution for the current problem.",
                                "Show the problem description page."
                            ]
                        },
                        "description": "Customize the shortcuts in editors."
                    },
                    "leetcodeMaster.enableSideMode": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Determine whether to group all webview pages into the second editor column when solving problems."
                    },
                    "leetcodeMaster.nodePath": {
                        "type": "string",
                        "default": "node",
                        "scope": "application",
                        "description": "The Node.js executable path. for example, C:\\Program Files\\nodejs\\node.exe"
                    },
                    "leetcodeMaster.colorizeProblems": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Add difficulty badge and colorize problems files in explorer tree."
                    },
                    "leetcodeMaster.problems.sortStrategy": {
                        "type": "string",
                        "default": "None",
                        "scope": "application",
                        "enum": [
                            "None",
                            "Acceptance Rate (Ascending)",
                            "Acceptance Rate (Descending)"
                        ],
                        "description": "Sorting strategy for problems list."
                    },
                    "leetcodeMaster.review.sortStrategy": {
                        "type": "string",
                        "default": "Sort By Next Scheduled Review (ASC)",
                        "scope": "application",
                        "enum": [
                            "Sort By Next Scheduled Review (ASC)",
                            "Sort By Next Scheduled Review (DESC)",
                            "Sort By Review Delayed Hours (ASC)",
                            "Sort By Review Delayed Hours (DESC)"
                        ],
                        "description": "Sorting strategy for the Review List."
                    },
                    "leetcodeMaster.review.dailyGoal": {
                        "type": "integer",
                        "default": 5,
                        "minimum": 1,
                        "scope": "application",
                        "description": "Daily target number of problems to review."
                    },
                    "leetcodeMaster.allowReportData": {
                        "type": "boolean",
                        "default": true,
                        "scope": "application",
                        "description": "Allow LeetCode to report anonymous usage data to improve the product."
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "tslint --project tsconfig.json -e src/*.d.ts -t verbose",
        "build": "npx @vscode/vsce package",
        "vs-publish": "npx @vscode/vsce publish"
    },
    "devDependencies": {
        "@types/fs-extra": "^9.0.11",
        "@types/lodash": "^4.14.170",
        "@types/markdown-it": "0.0.7",
        "@types/mocha": "^2.2.42",
        "@types/node": "^14.14.33",
        "@types/require-from-string": "^1.2.0",
        "@types/vscode": "1.57.0",
        "tslint": "^5.20.1",
        "typescript": "^4.3.2"
    },
    "dependencies": {
        "axios": "^1.6.8",
        "fs-extra": "^10.0.0",
        "highlight.js": "^10.7.2",
        "lodash": "^4.17.21",
        "markdown-it": "^8.4.2",
        "require-from-string": "^2.0.2",
        "unescape-js": "^1.1.4",
        "vsc-leetcode-cli": "2.8.1"
    }
}
